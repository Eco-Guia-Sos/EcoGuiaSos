# URL y Clave Pública de Supabase (Acceso del Frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Clave Privada de Servicio (Servidor / Edge Functions únicamente - NO agregar prefijo VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Clave Externa (Ejemplo de API Key externa para el cliente)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Cloudflare Turnstile
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Sentry
VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Upstash Redis (Edge Functions Rate Limit)
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# INEGI API (Territory Proxy)
INEGI_API_KEY=your-inegi-api-key
